# Strategy 5.x Growth System — Environment Variables
# Copy this file to .env and fill in your values

# ── Required (system won't start without these) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Optional: AI Dissent (Perplexity Sonar) ──
AI_DISSENT_ENABLED=false
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Moomoo OpenAPI (live position sync) ──
MOOMOO_ENABLED=false
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
MOOMOO_TRADE_ENV=REAL
